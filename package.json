{
  "name": "playground_sdk",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
